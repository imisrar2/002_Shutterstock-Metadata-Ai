{
  "name": "shutterstock-ai-metadata-studio",
  "version": "1.0.0",
  "description": "Chrome MV3 extension that automates Shutterstock contributor metadata generation using Gemini Vision.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/build.mjs --watch",
    "build": "node scripts/build.mjs",
    "typecheck": "tsc --noEmit",
    "package": "npm run build && node scripts/package.mjs"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.270",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "esbuild": "^0.23.1"
  }
}
